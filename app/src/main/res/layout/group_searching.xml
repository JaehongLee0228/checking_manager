<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".group_searching">


    <com.checking_manager.checking_manager.ClearEditText
        android:id="@+id/group_name_search_EditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10dp"
        android:ems="10"
        android:hint="그룹 이름"
        android:inputType="textPersonName" />

    <Button
        android:id="@+id/group_name_search_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="검색" />

    <TextView
        android:id="@+id/group_search_result_TextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center" />

    <Button
        android:id="@+id/searching_group_join_button"
        android:text="그룹 참가 신청"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
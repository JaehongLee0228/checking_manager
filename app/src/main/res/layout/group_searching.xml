<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".group_searching"
    android:background="@color/back_app"
    android:padding="15dp"
    android:gravity="center">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="30dp">

        <com.checking_manager.checking_manager.ClearEditText
            android:id="@+id/group_name_search_EditText"
            style="@style/EditTextStyle"
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:ems="10"
            android:hint="Search Group Name"
            android:inputType="textPersonName"
            android:padding="10dp"
            android:textSize="20sp"
            android:theme="@style/EditTextStyle" />

        <Button
            android:id="@+id/group_name_search_button"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Search"
            android:background="@drawable/btn_purple"
            android:textColor="@drawable/btn_textcolor"
            android:textAllCaps="false"/>

    </LinearLayout>

    <TextView
        android:id="@+id/group_search_result_TextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="20sp"
        android:textColor="@color/white"/>

    <Button
        android:id="@+id/searching_group_join_button"
        android:text="그룹 참가 신청"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/btn_purple"
        android:textColor="@drawable/btn_textcolor"
        android:textAllCaps="false"
        android:layout_marginTop="30dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"/>

</LinearLayout>
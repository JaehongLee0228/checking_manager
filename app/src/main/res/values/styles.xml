<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/back_app</item>
        <item name="colorPrimaryDark">@color/back_app</item>
        <item name="colorAccent">@color/btn_purple</item>
    </style>

    <style name="EditTextStyle" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorControlNormal">@color/et_text</item>
        <item name="colorControlActivated">@color/btn_purple</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorHint">@color/et_text</item>
    </style>



</resources>
